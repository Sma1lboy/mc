{
  "$schema": "https://schema.tauri.app/config/2",
  "identifier": "com.sma1lboy.mclauncher.e2e",
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "kobeMC E2E",
        "width": 1180,
        "height": 760,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "incognito": true
      }
    ],
    "security": {
      "capabilities": [
        "default",
        {
          "identifier": "e2e-wdio",
          "description": "WDIO bridge available only in the explicit E2E build flavor.",
          "windows": ["main"],
          "permissions": ["wdio:default", "wdio-webdriver:default"]
        }
      ]
    }
  },
  "bundle": {
    "active": false
  }
}
