# mc-launcher desktop — local dev env. Copy to `.env` (gitignored) and fill in.
# scripts/dev-app.sh sources this and the launched binary inherits it.

# Microsoft login (device-code flow). REQUIRED for 微软登录 to work.
# The default vanilla id (00000000402b5328) is a legacy Live app the Azure AD
# v2.0 device-code endpoint rejects (AADSTS700016). Register your own Azure app:
#
#   1. https://portal.azure.com → Microsoft Entra ID → App registrations → New registration
#   2. Name: anything.  Supported account types: "Personal Microsoft accounts only".
#      Redirect URI: leave empty.  → Register.
#   3. Copy the "Application (client) ID" → paste below.
#   4. Authentication → Advanced settings → "Allow public client flows" = Yes → Save.
#      (this enables the device-code flow)
#
# No client secret is needed (public client / device-code).
MC_MSA_CLIENT_ID=

# Our backend (email/password via better-auth). Point at the local mc-server.
# MC_SERVER_URL=http://127.0.0.1:8787

# AI agent provider. scripts/dev-app.sh sources this file, and the Rust CLI
# also searches for desktop/src-tauri/.env when run from the repo.
#
OPENROUTER_API_KEY=
# Optional OpenRouter overrides:
# OPENROUTER_MODEL=openai/gpt-5.4-mini
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
