{
  "compilerOptions": {
    /* React 17+ 自动运行时:无需手动 import React。 */
    "jsx": "react-jsx",

    /* 现代 ES 目标,配合 Vite 的 esnext 产物。 */
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",

    /* 严格类型检查(production-ready 前提)。 */
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

    /* Vite 客户端类型(import.meta.env 等)。 */
    "types": ["vite/client"],

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "noEmit": true,
    "allowJs": false,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src"],
  /* migration: 死掉的 Solid 文件,等 owner 批准后删除(见 PR 的删除清单);排除以保持门禁诚实。 */
  "exclude": ["src/index.tsx", "src/motion/solid.tsx", "src/motion/index.ts"]
}
