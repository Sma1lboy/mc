# Copy to `.env` (same dir) and fill in. Real env vars override this file.
# Get the value from Supabase: Project → Connect → "Session pooler" → URI.
# Use the SESSION POOLER (port 5432) for a long-running server — it keeps
# prepared statements working (the transaction pooler on 6543 does not).
#
# Format:
#   postgresql://postgres.<project-ref>:<DB-PASSWORD>@aws-0-<region>.pooler.supabase.com:5432/postgres
#
# The server auto-creates its tables (better-auth: users / sessions / accounts /
# verifications, plus our shares) on first connect — nothing to run by hand.
#
# AUTH_SECRET: 32+ char signing secret for better-auth sessions (set in prod).
# AUTH_SECRET=change-me-to-a-long-random-secret-string

DATABASE_URL=postgresql://postgres.your-project-ref:YOUR-DB-PASSWORD@aws-0-us-east-1.pooler.supabase.com:5432/postgres

# Optional: server port (default 8787)
# PORT=8787
