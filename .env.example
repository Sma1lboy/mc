# Repository-level local dev env. Copy to `.env` at the repository root.
# Real env vars override this file. Never commit `.env`.

# AI agent provider.
OPENROUTER_API_KEY=

# Optional OpenRouter overrides (default model is deepseek/deepseek-v4-pro):
